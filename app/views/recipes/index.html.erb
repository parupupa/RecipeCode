<h1>レシピ一覧</h1>

<%= link_to "レシピを作成する", new_recipe_path %>
<%= link_to "マイページへ戻る", mypage_path %>

<% if @recipes.any? %>
  <ul>
    <% @recipes.each do |recipe| %>
      <% latest_version = recipe.recipe_versions.order(version_number: :desc).first %>

      <li>
        <h2><%= recipe.title %></h2>

        <p>
          改良履歴数：<%= recipe.recipe_versions.size %>
        </p>

        <p>
          最新版作成日：
          <% if latest_version.present? %>
            <%= l latest_version.created_at, format: :short %>
          <% else %>
            まだありません
          <% end %>
        </p>

        <p>
          レシピ詳細ページは後続issueで作成予定です
        </p>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>まだレシピがありません。</p>
<% end %>