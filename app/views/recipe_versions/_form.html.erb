<% if recipe_version.errors.any? %>
  <div>
    <h2>入力内容を確認してください</h2>
    <ul>
      <% recipe_version.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<% form_model = recipe_version.persisted? ? recipe_version : [recipe, recipe_version] %>

<%= form_with model: form_model, local: true do |f| %>

  <div>
    <strong>バージョン番号：</strong>
    <span><%= recipe_version.version_number %></span>
  </div>

  <div>
    <%= f.label :version_name, "バージョン名" %>
    <%= f.text_field :version_name %>
  </div>

  <div>
    <%= f.label :ingredients, "材料" %>
    <%= f.text_area :ingredients, rows: 5 %>
  </div>

  <div>
    <%= f.label :steps, "手順" %>
    <%= f.text_area :steps, rows: 5 %>
  </div>

  <div>
    <%= f.label :memo, "メモ" %>
    <%= f.text_area :memo, rows: 3 %>
  </div>

  <div>
    <%= f.label :images, "画像" %>
    <%= f.file_field :images, multiple: true %>
  </div>

  <div>
    <%= f.submit "保存する" %>
  </div>
<% end %>