<% if recipe_version.errors.any? %>
  <div class="mb-4 text-sm text-gray-600">
    <p class="font-medium text-gray-700">入力内容を確認してください</p>
    <ul class="mt-1 list-disc pl-5">
      <% recipe_version.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<% form_model = recipe_version.persisted? ? recipe_version : [recipe, recipe_version] %>

<%= form_with model: form_model, local: true, class: "space-y-4" do |f| %>

  <div class="text-sm text-gray-600">
    <span class="font-medium text-gray-700">バージョン番号：</span>
    <span>v<%= recipe_version.version_number %></span>
  </div>

  <div>
    <%= f.label :version_name, "バージョン名",
                class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :version_name,
                     class: "mt-1 w-full rounded-lg bg-white px-3 py-2 text-gray-900 shadow-sm" %>
  </div>

  <div>
    <%= f.label :ingredients, "材料",
                class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :ingredients,
                    rows: 8,
                    class: "mt-1 w-full rounded-lg bg-white px-3 py-2 text-gray-900 shadow-sm" %>
  </div>

  <div>
    <%= f.label :steps, "手順",
                class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :steps,
                    rows: 10,
                    class: "mt-1 w-full rounded-lg bg-white px-3 py-2 text-gray-900 shadow-sm" %>
  </div>

  <div>
    <%= f.label :memo, "メモ",
                class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :memo,
                    rows: 3,
                    class: "mt-1 w-full rounded-lg bg-white px-3 py-2 text-gray-900 shadow-sm" %>
  </div>

  <div>
    <%= f.label :images, "画像",
                class: "block text-sm font-medium text-gray-700" %>

    <%= f.file_field :images,
                    multiple: true,
                    class: "mt-1 w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-sm text-gray-600 file:mr-3 file:rounded-md file:border-0 file:bg-zinc-600 file:px-3 file:py-1.5 file:text-sm file:text-white hover:file:bg-zinc-700" %>
  </div>

  <div class="mt-8">
    <%= f.submit "保存する",
                 class: "w-full rounded-md bg-lime-600 px-4 py-2 text-stone-50 hover:bg-lime-950" %>
  </div>

<% end %>