<% content_for :body_class do %>
  bg-white text-gray-900
<% end %>

<section class="mx-auto max-w-2xl rounded-lg bg-lime-700 px-1 py-1 shadow-sm">
  <div class="rounded-lg bg-white px-4 py-4 shadow-sm space-y-3">

    <h2 class="text-sm tracking-tight text-gray-700">
      レシピの改良履歴を一覧できます。
    </h2>

    <div class="border-b border-stone-300 pb-3 flex justify-between items-center gap-3">
      <h1 class="text-2xl font-bold tracking-tight text-gray-900">
        <%= @recipe.title %>
      </h1>
      <%= link_to "＋ 新しいバージョンを作る",
                  new_recipe_recipe_version_path(@recipe),
                  class: "rounded-md bg-lime-600 px-4 py-2 text-stone-50 shadow-sm transition hover:bg-lime-900 hover:text-white" %>
    </div>

    <div class="p-2 bg-stone-50">
      <% if @recipe_versions.any? %>
        <ul>
          <% @recipe_versions.each do |recipe_version| %>
            <li class="flex justify-between items-center border-b border-stone-200 py-4 first:pt-0 last:border-b-0 last:pb-0">
              
              <div class="flex-1">
                <div class="flex items-center gap-6">
                  
                  <div class="flex items-center gap-2">
                    <h2 class="text-xl font-semibold">
                      <%= link_to recipe_version.version_name,
                            recipe_version_path(recipe_version),
                            class: "text-gray-900 hover:text-gray-300" %>
                    </h2>

                    <% if recipe_version == @recipe.latest_version %>
                      <span class="inline-block rounded-full border border-stone-300 bg-white px-2 py-0.5 text-xs text-gray-600">
                        最新版
                      </span>
                    <% end %>
                  </div>

                  <div class="text-sm text-gray-600">
                    <span>v<%= recipe_version.version_number %></span>
                    <span class="mx-2 text-gray-400">/</span>
                    <span><%= l recipe_version.created_at, format: :short %></span>
                  </div>

                </div>

                <% if recipe_version.memo.present? %>
                  <div class="mt-2 text-sm text-gray-700">
                    <%= simple_format(recipe_version.memo) %>
                  </div>
                <% end %>
              </div>

              <div class="flex items-center pl-6">
                <%= link_to "詳細",
                      recipe_version_path(recipe_version),
                      class: "pr-6 text-sm text-gray-600 hover:text-gray-300" %>
              </div>

            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="rounded-xl bg-stone-50 p-6 shadow-sm">
          <p class="text-gray-700">
            改良履歴はまだありません。
          </p>
        </div>
      <% end %>
    </div>

    <div class="mt-5">
      <%= link_to "レシピ詳細へ戻る",
                    recipe_path(@recipe),
                    class: "rounded-md border border-gray-700 bg-white px-4 py-2 text-gray-700 shadow-sm transition hover:bg-gray-200 hover:text-gray-700" %>
    </div>

  </div>
</section>