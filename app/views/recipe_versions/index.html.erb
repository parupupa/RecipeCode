<% content_for :body_class do %>
  bg-white text-gray-900
<% end %>
<section class="mx-auto max-w-2xl rounded-lg bg-lime-700 px-1 py-1 shadow-sm">
  <div class="space-y-3 rounded-lg bg-white px-4 py-4 shadow-sm">
    <h2 class="text-sm tracking-tight text-gray-700">
      レシピの改良履歴を一覧できます。
    </h2>
    <div class="border-b border-stone-300 pb-3">
      <div class="min-w-0">
        <h1 class="truncate whitespace-nowrap text-2xl font-bold tracking-tight text-gray-900">
          <%= @recipe.title %>
        </h1>
      </div>
      <div class="mt-3 flex justify-end">
        <%= link_to "＋ 新しいバージョンを作る",
                    new_recipe_recipe_version_path(@recipe),
                    class: "whitespace-nowrap rounded-md bg-lime-600 px-4 py-2 text-sm text-stone-50 shadow-sm transition hover:bg-lime-900 hover:text-white sm:text-base" %>
      </div>
    </div>
    <div class="bg-stone-50 p-2">
      <% if @recipe_versions.any? %>
        <ul>
          <% @recipe_versions.each do |recipe_version| %>
            <li class="border-b border-stone-200 py-4 first:pt-0 last:border-b-0 last:pb-0">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2 sm:gap-4">
                    <div class="flex min-w-0 items-center gap-2">
                      <h2 class="min-w-0 truncate whitespace-nowrap text-lg font-semibold sm:text-xl">
                        <%= link_to recipe_version.version_name,
                              recipe_version_path(recipe_version),
                              class: "block truncate whitespace-nowrap text-gray-900 hover:text-gray-300" %>
                      </h2>
                      <% if recipe_version == @recipe.latest_version %>
                        <span class="shrink-0 whitespace-nowrap rounded-full border border-stone-300 bg-white px-2 py-0.5 text-xs text-gray-600">
                          最新版
                        </span>
                      <% end %>
                    </div>
                    <div class="whitespace-nowrap text-sm text-gray-600">
                      <span>v<%= recipe_version.version_number %></span>
                      <span class="mx-2 text-gray-400">/</span>
                      <span><%= l recipe_version.created_at, format: :short %></span>
                    </div>
                  </div>
                  <% if recipe_version.memo.present? %>
                    <div class="mt-2 break-words text-sm text-gray-700">
                      <%= simple_format(recipe_version.memo) %>
                    </div>
                  <% end %>
                </div>
                <div class="shrink-0 pl-3">
                  <%= link_to "詳細",
                        recipe_version_path(recipe_version),
                        class: "whitespace-nowrap text-sm text-gray-600 hover:text-gray-300" %>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="rounded-xl bg-stone-50 p-6 shadow-sm">
          <p class="text-gray-700">
            改良履歴はまだありません。
          </p>
        </div>
      <% end %>
    </div>
    <div class="mt-5 text-center sm:text-left">
      <%= link_to "レシピ詳細へ戻る",
                    recipe_path(@recipe),
                    class: "whitespace-nowrap rounded-md border border-gray-700 bg-white px-4 py-2 text-gray-700 shadow-sm transition hover:bg-gray-200 hover:text-gray-700" %>
    </div>
  </div>
</section>