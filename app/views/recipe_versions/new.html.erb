<% content_for :body_class do %>
  bg-white text-gray-900
<% end %>

<section class="mx-auto max-w-2xl rounded-lg bg-lime-700 px-1 py-1 shadow-sm">
  <div class="rounded-lg bg-white px-3 py-3 shadow-sm">

    <h2 class="text-sm tracking-tight text-gray-700">
      レシピの新しいバージョンを記録できます。
    </h2>

    <div class="border-b pb-3">
      <div class="min-w-0">
        <h1 class="mt-3 truncate whitespace-nowrap text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
          <%= @recipe.title %>
        </h1>
      </div>
    </div>

    <div class="mt-4 rounded-lg bg-stone-50 px-4 py-4 shadow-sm">
      <%= render "form",
                 recipe: @recipe,
                 recipe_version: @recipe_version %>
    </div>

    <div class="mt-8 text-center sm:text-left">
      <%= link_to "保存せずに戻る",
                  recipe_path(@recipe),
                  class: "whitespace-nowrap rounded-md px-4 py-2 text-gray-700 shadow-sm transition hover:bg-gray-200 hover:text-gray-700" %>
    </div>

  </div>
</section>