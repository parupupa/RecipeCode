<section>
  <h1>アカウント削除</h1>

  <div>
    <p>
      アカウントを削除すると、登録情報は削除されます。
    </p>
    <p>
      この操作は取り消せません。
    </p>
  </div>

  <div>
    <p>
      ユーザー名：<%= current_user.name %>
    </p>
    <p>
      メールアドレス：<%= current_user.email %>
    </p>
  </div>

  <div>
    <%= link_to "削除せずにマイページへ戻る", mypage_path %>

    <%= button_to "アカウントを削除する",
                  user_registration_path,
                  method: :delete,
                  data: { turbo_confirm: "本当にアカウントを削除しますか？" } %>
  </div>
</section>