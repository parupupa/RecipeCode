<section class="mx-auto max-w-2xl space-y-3">
  <div class="border-b border-stone-300 pb-3">
    <h1 class="text-2xl font-bold tracking-tight text-gray-900">
      アカウント削除
    </h1>
  </div>

  <div class="rounded-xl bg-stone-50 p-6 shadow-sm">
    <p class="text-gray-700">
      アカウントを削除すると、登録情報は削除されます。
    </p>
    <p class="mt-2 text-gray-700">
      この操作は取り消せません。
    </p>
    
    <p class="mt-2 text-gray-700">
      ユーザー名：<%= current_user.name %>
    </p>
    <p class="mt-2 text-gray-700">
      メールアドレス：<%= current_user.email %>
    </p>
  </div>

  <div class="flex items-center gap-4">
    <%= link_to "削除せずにマイページへ戻る",
                mypage_path,
                class: "rounded-md border border-transparent bg-white px-4 py-2 text-gray-600 shadow-sm transition hover:border-gray-400" %>

    <%= button_to "アカウントを削除する",
                  user_registration_path,
                  method: :delete,
                  data: { turbo_confirm: "本当にアカウントを削除しますか？" },
                  form_class: "inline-block",
                  class: "rounded-md bg-red-700 px-4 py-2 text-white hover:bg-red-800" %>
  </div>
</section>