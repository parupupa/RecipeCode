<!DOCTYPE html>
<html>
  <head>
    <title>RecipeCode</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex min-h-screen flex-col bg-stone-100 text-gray-900">
    <%= render "shared/header" %>

    <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-6">
      <% if notice %>
        <div class="mb-4 rounded-md border border-lime-900 bg-stone-50 px-4 py-3">
          <p class="text-sm text-lime-900"><%= notice %></p>
        </div>
      <% end %>

      <% if alert %>
        <div class="mb-4 rounded-md border border-stone-300 bg-stone-50 px-4 py-3">
          <p class="text-sm text-gray-700"><%= alert %></p>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
